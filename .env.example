# Claude API (console.anthropic.com 에서 발급)
CLAUDE_API_KEY=sk-ant-여기에_키_입력

# 텔레그램 봇 설정
# 1. 텔레그램에서 @BotFather 검색
# 2. /newbot 입력 후 봇 이름 설정
# 3. 발급된 토큰을 아래에 입력
TELEGRAM_BOT_TOKEN=여기에_봇_토큰_입력

# 본인 텔레그램 Chat ID
# @userinfobot 에게 메시지 보내면 알려줌
TELEGRAM_CHAT_ID=여기에_숫자_ID_입력

# Blogger 블로그 ID (URL에서 확인 가능)
BLOG_ID=2714213792568384338
